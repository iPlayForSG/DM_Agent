# OpenAI-compatible model settings used through LangGraph
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_MODEL=glm-5.1

# Local RAG index settings. Generated indexes stay under backend/Knowledge and are ignored by git.
RAG_SOURCE_ROOT=Documents/DND5e 2024
RAG_VECTOR_DB_PATH=Knowledge/vector_db
RAG_COLLECTION_NAME=dnd_rules_qwen3_embedding_8b
RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
RAG_MODEL_CACHE=Knowledge/hf_cache
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=80
RAG_EMBEDDING_BATCH_SIZE=1
RAG_UPSERT_BATCH_SIZE=16
RAG_EMBEDDING_DEVICE=
RAG_CPU_CHUNK_LIMIT=32
RAG_ALLOW_SLOW_CPU=false
RAG_AUTO_CONTEXT_RESULTS=3
RAG_MAX_CONTEXT_CHARS=6000
RAG_MAX_SNIPPET_CHARS=1800
RAG_MAX_RESULTS_PER_SOURCE=2
