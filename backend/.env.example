# OpenAI-compatible model settings used through Google ADK + LiteLLM or LangGraph
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.z.ai/api/paas/v4/
OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/
LLM_MODEL=glm-5.1

# Keep google-adk for the stable path; set to langgraph when testing the new runner.
CHAT_BACKEND=google-adk

# Optional ADK runtime labels
ADK_APP_NAME=dnd_dm_agent
ADK_USER_ID=local_dm
