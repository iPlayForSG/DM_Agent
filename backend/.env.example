# OpenAI-compatible model settings used through LangGraph
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_MODEL=glm-5.1

# LangGraph checkpoint persistence. Use sqlite for resumable local workflows.
LANGGRAPH_CHECKPOINT_MODE=sqlite
LANGGRAPH_CHECKPOINT_DB_PATH=Game/langgraph_checkpoints.sqlite

# Local RAG index settings. Generated indexes stay under backend/Knowledge and are ignored by git.
RAG_SOURCE_ROOT=Documents/DND5e 2024
RAG_VECTOR_DB_PATH=Knowledge/vector_db
RAG_COLLECTION_NAME=dnd_rules_qwen3_embedding_4b_q6_k
RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B-GGUF
RAG_MODEL_CACHE=Knowledge/hf_cache
RAG_GGUF_FILENAME=Qwen3-Embedding-4B-Q6_K.gguf
RAG_LLAMA_CPP_DIR=Knowledge/llama_cpp/b8833-cuda12
RAG_LLAMA_SERVER_PORT=8092
RAG_LLAMA_SERVER_GPU_LAYERS=999
RAG_LLAMA_SERVER_CTX=4096
RAG_LLAMA_SERVER_UBATCH=8192
RAG_LLAMA_SERVER_STARTUP_TIMEOUT_S=180
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=80
RAG_EMBEDDING_BATCH_SIZE=32
RAG_UPSERT_BATCH_SIZE=32
RAG_EMBEDDING_DEVICE=cuda
RAG_EMBEDDING_MAX_RETRIES=3
RAG_EMBEDDING_MIN_BATCH_SIZE=8
RAG_CPU_CHUNK_LIMIT=32
RAG_ALLOW_SLOW_CPU=false
RAG_AUTO_CONTEXT_RESULTS=3
RAG_QUERY_INSTRUCT=Given a web search query, retrieve relevant passages that answer the query
RAG_MAX_CONTEXT_CHARS=6000
RAG_MAX_SNIPPET_CHARS=1800
RAG_MAX_RESULTS_PER_SOURCE=2
RAG_RERANK_ENABLED=true
